{
  "name": "libretto-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.51",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/openai": "^3.0.41",
    "@types/sharp": "^0.32.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "turbo": "^2.8.20"
  },
  "scripts": {
    "build": "turbo run build",
    "website:build": "pnpm --dir ./apps/website build",
    "sync:mirrors": "node packages/dev-tools/scripts/sync-mirrors.mjs",
    "check:mirrors": "node packages/dev-tools/scripts/check-mirrors-sync.mjs",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "prepare-release": "bash ./scripts/prepare-release.sh",
    "evals": "turbo run evals --filter=libretto-evals --",
    "benchmarks": "turbo run benchmarks --filter=libretto-benchmarks --",
    "google-login": "gcloud auth login --update-adc && gcloud auth configure-docker us-central1-docker.pkg.dev --quiet",
    "cli": "pnpm --filter libretto cli",
    "website:dev": "pnpm --dir ./apps/website dev"
  }
}
